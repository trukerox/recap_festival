{
  "name": "festival_recap",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted service that turns uploaded festival photos/clips into a 20s vertical recap video",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "node src/db/migrate.js",
    "worker": "node src/queue/worker.js",
    "seed-music": "node scripts/seed-music.js",
    "cleanup": "node scripts/cleanup.js",
    "test": "node --test"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.12.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "sharp": "^0.33.5",
    "zod": "^3.24.1"
  }
}
