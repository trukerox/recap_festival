# Non-secret config only. Secrets (db_password, jwt_secret) are Docker
# secrets — see docker-compose.yml and secrets/*.txt.

PORT=3000

# Public base URL used to build download links returned by the API.
PUBLIC_BASE_URL=https://festival_recap.homeserver.fritz.box

# Render tuning
RENDER_CONCURRENCY=1
RENDER_WIDTH=1080
RENDER_HEIGHT=1920
RENDER_DURATION_SECONDS=20
RENDER_QUEUE_POLL_MS=3000

# ffmpeg preset: ultrafast|superfast|veryfast|faster|fast|medium
# Keep at ultrafast/superfast on Pi — anything slower makes 20s of 1080x1920
# multi-filter video take minutes per job on CPU-only encode.
FFMPEG_PRESET=veryfast

# Upload limits
MAX_UPLOAD_FILES=40
MAX_UPLOAD_FILE_MB=100
MAX_UPLOAD_TOTAL_MB=1000

# Retention: auto-delete uploads + renders older than N days (0 = disabled)
RETENTION_DAYS=14
